# ==============================================================================
# VARIABLES DE ENTORNO - BACKEND NODE.JS (Liga Maestre API)
# ==============================================================================
# Copia este archivo como .env y ajusta los valores según el entorno.
# NUNCA subas el archivo .env real al repositorio.
# ==============================================================================

# ------------------------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------------------------
NODE_ENV=development              # development | production

# ------------------------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------------------------
PORT=3000                         # Puerto en el que escucha el servidor Express

# ------------------------------------------------------------------------------
# BASE DE DATOS - MONGODB
# Desarrollo: cadena local (MongoDB local o MongoDB Atlas gratuito)
# Producción: cadena de conexión completa de MongoDB Atlas u otro proveedor
#
# Formato local:      mongodb://localhost:27017/liga_maestre
# Formato Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/liga_maestre
# ------------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/liga_maestre
