# ==============================================================================
# VARIABLES DE ENTORNO - FRONTEND ANGULAR (Liga Maestre)
# ==============================================================================
# Angular NO usa archivos .env en tiempo de ejecución.
# La configuración se inyecta en tiempo de compilación a través de los archivos:
#
#   src/environments/environment.ts          → desarrollo  (ng serve)
#   src/environments/environment.prod.ts     → producción  (ng build --configuration production)
#
# Este archivo documenta qué valores debes configurar en esos archivos antes
# de compilar o desplegar la aplicación.
# ==============================================================================

# ------------------------------------------------------------------------------
# ARCHIVO: src/environments/environment.ts  (DESARROLLO)
# ------------------------------------------------------------------------------
# export const environment = {
#   production: false,
#   apiUrl: 'http://localhost:8000/api',   ← URL del backend Laravel en local
# };

# ------------------------------------------------------------------------------
# ARCHIVO: src/environments/environment.prod.ts  (PRODUCCIÓN)
# ------------------------------------------------------------------------------
# export const environment = {
#   production: true,
#   apiUrl: 'https://<tu-dominio-railway>.up.railway.app/api',  ← URL pública del backend
# };
#
# Ejemplo actual:
# apiUrl: 'https://monorepo-copy-production-6c9d.up.railway.app/api'

# ------------------------------------------------------------------------------
# RESUMEN DE VARIABLES POR ENTORNO
# ------------------------------------------------------------------------------
# Variable    | Desarrollo                        | Producción
# ------------|-----------------------------------|----------------------------------
# production  | false                             | true
# apiUrl      | http://localhost:8000/api          | https://<dominio>/api
# ------------------------------------------------------------------------------
#
# NOTA: Si se añaden más variables de entorno al proyecto (tokens, feature flags,
# claves de analytics, etc.), agrégalas a ambos archivos environment.*.ts y
# documéntalas en esta sección.
