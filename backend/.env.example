# ==============================================================================
# VARIABLES DE ENTORNO - BACKEND LARAVEL (Liga Maestre)
# ==============================================================================
# Copia este archivo como .env y ajusta los valores según el entorno.
# NUNCA subas el archivo .env real al repositorio.
# ==============================================================================

# ------------------------------------------------------------------------------
# APLICACIÓN
# ------------------------------------------------------------------------------
APP_NAME="Liga Maestre"
APP_ENV=local                    # local | production | staging
APP_KEY=                         # Generar con: php artisan key:generate
# PRODUCCIÓN: APP_DEBUG debe ser false para no exponer información sensible
APP_DEBUG=true                   # false en producción (obligatorio)
APP_URL=http://localhost          # URL pública de la app (ej: https://mi-app.railway.app)
ASSET_URL=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# LOGGING
# Producción recomendado: LOG_LEVEL=error o warning
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                  # debug | info | warning | error (usar error en producción)

# ------------------------------------------------------------------------------
# BASE DE DATOS
# Desarrollo: credenciales locales
# Producción: usar variables del proveedor (Railway, etc.) — no hardcodear
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                # Railway: valor de ${{MySQL.MYSQL_HOST}}
DB_PORT=3306                     # Railway: valor de ${{MySQL.MYSQL_PORT}}
DB_DATABASE=liga_maestre         # Railway: nombre de la base de datos creada
DB_USERNAME=root                 # Railway: valor de ${{MySQL.MYSQL_USER}}
DB_PASSWORD=                     # Railway: valor de ${{MySQL.MYSQL_PASSWORD}} — NO dejar vacío en producción

# ------------------------------------------------------------------------------
# SESIONES Y CACHÉ
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ------------------------------------------------------------------------------
# REDIS (opcional — solo si se usa Redis)
# ------------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# CORREO
# Desarrollo: driver "log" escribe en storage/logs en lugar de enviar emails
# Producción: configurar SMTP real (ej: Mailgun, SendGrid, Gmail)
# ------------------------------------------------------------------------------
MAIL_MAILER=log                  # smtp en producción
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1              # ej: smtp.mailgun.org
MAIL_PORT=2525                   # ej: 587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ligamaestre.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# AWS S3 (opcional — solo si se almacenan archivos en S3)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# FRONTEND / VITE
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
